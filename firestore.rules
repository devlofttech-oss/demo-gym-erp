rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDocData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && userDocExists() && userDocData().role == 'superadmin';
    }

    function isAdminOf(gymId) {
      return isSignedIn() && userDocExists()
        && userDocData().role == 'admin'
        && userDocData().gymId == gymId;
    }

    function isStaffOf(gymId) {
      return isSignedIn() && userDocExists()
        && userDocData().role == 'staff'
        && userDocData().gymId == gymId;
    }

    // ── Users collection ─────────────────────────────────────────
    match /users/{userId} {
      // User reads their own doc; superadmin reads all
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());

      // Any authenticated user can create their own doc
      // (needed for superadmin bootstrap — no users doc exists yet to check against)
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Superadmin creates gym owner accounts (secondary app pattern)
      allow create: if isSuperAdmin();

      // Admin creates staff accounts for their own gym (secondary app pattern)
      allow create: if isSignedIn() && userDocExists()
        && userDocData().role == 'admin'
        && request.resource.data.gymId == userDocData().gymId
        && request.resource.data.role == 'staff';

      // User updates their own doc; superadmin updates anyone;
      // admin updates their gym's staff
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (userDocExists()
          && userDocData().role == 'admin'
          && resource.data.gymId == userDocData().gymId
          && resource.data.role == 'staff')
      );

      // Superadmin deletes anyone; admin deletes their gym's staff
      allow delete: if isSuperAdmin() || (
        isSignedIn() && userDocExists()
        && userDocData().role == 'admin'
        && resource.data.gymId == userDocData().gymId
        && resource.data.role == 'staff'
      );
    }

    // ── Gym metadata (root gyms collection) ──────────────────────
    match /gyms/{gymId} {
      // Admin/staff read their own gym doc (AuthContext loads gymData on login)
      allow read: if isSignedIn() && (
        isSuperAdmin() || isAdminOf(gymId) || isStaffOf(gymId)
      );
      // Only superadmin can create, update, or delete gym records
      allow write: if isSuperAdmin();
    }

    // ── Gym tenant data ───────────────────────────────────────────
    match /gyms/{gymId}/{collection}/{docId} {
      // Superadmin and gym admin: full access
      allow read, write: if isSuperAdmin() || isAdminOf(gymId);

      // Staff: read members and attendance (for check-in lookup)
      allow read: if isStaffOf(gymId) && collection in ['members', 'attendance'];

      // Staff: write attendance; update members (lastCheckin timestamp)
      allow create: if isStaffOf(gymId) && collection == 'attendance';
      allow update: if isStaffOf(gymId) && collection in ['attendance', 'members'];
    }
  }
}
